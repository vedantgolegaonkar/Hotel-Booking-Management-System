# API URL for Next.js app to fetch data from the Spring Boot backend.
# In local development, the backend defaults to port 8080: http://localhost:8080/api/v1
# In Vercel (Production), set this environment variable to your deployed backend API URL (e.g. https://your-backend.herokuapp.com/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
